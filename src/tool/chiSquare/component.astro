---
import { Icon } from 'astro-icon/components';
import type { ChiSquareUI } from './ui';

interface Props {
  ui: ChiSquareUI;
}

const { ui } = Astro.props;
---

<div
  class="chi-card"
  id="chiApp"
  data-row={ui.rowLabel}
  data-col={ui.colLabel}
  data-total={ui.totalLabel}
  data-cramer-null={ui.cramerNull}
  data-cramer-weak={ui.cramerWeak}
  data-cramer-moderate={ui.cramerModerate}
  data-cramer-strong={ui.cramerStrong}
  data-sig-text={ui.sigText}
  data-no-sig-text={ui.noSigText}
  data-chart-obs={ui.chartLegendObs}
  data-chart-exp={ui.chartLegendExp}
  data-copy-label={ui.btnCopy}
  data-copied-label={ui.btnCopied}
  data-just-intro={ui.justificationIntro}
  data-just-table-of={ui.justificationTableOf}
  data-just-obtained={ui.justificationObtained}
  data-just-p-at={ui.justificationPAt}
  data-just-concluded={ui.justificationConcluded}
  data-just-sig={ui.justificationSig}
  data-just-no-sig={ui.justificationNoSig}
>
  <aside class="chi-sidebar">
    <div class="chi-sidebar-heading">
      <Icon name="mdi:tune-vertical" /> {ui.labelConfig}
    </div>

    <div class="chi-group-section">
      <div class="chi-input-row">
        <label for="tableSize">{ui.labelTableSize}</label>
        <select id="tableSize">
          <option value="2x2" selected>{ui.alpha90.includes('90') ? '2 × 2' : '2 × 2'}</option>
          <option value="2x3">2 × 3</option>
          <option value="3x2">3 × 2</option>
          <option value="3x3">3 × 3</option>
        </select>
      </div>
      <div class="chi-input-row" style="margin-top: 0.5rem;">
        <label for="alpha">{ui.labelAlpha}</label>
        <select id="alpha">
          <option value="0.10">{ui.alpha90}</option>
          <option value="0.05" selected>{ui.alpha95}</option>
          <option value="0.01">{ui.alpha99}</option>
        </select>
      </div>
    </div>

    <div class="chi-info-box">
      <Icon name="mdi:information-outline" class="chi-info-icon" />
      <p class="chi-info-text">
        {ui.infoText}
      </p>
    </div>
  </aside>

  <main class="chi-main">
    <div class="chi-table-container">
      <div class="chi-table-title"><Icon name="mdi:table-edit" /> {ui.labelObserved}</div>
      <table class="chi-contingency-table" id="obsTable">
        <tbody></tbody>
      </table>
    </div>

    <div class="chi-expected-area">
      <button class="chi-expected-toggle" id="expectedBtn">
        <Icon name="mdi:chevron-right" id="expectedIcon" /> {ui.btnShowExpected}
      </button>
      <div class="chi-expected-content" id="expectedContent">
        <p class="chi-expected-desc">{ui.expectedDesc}</p>
        <div class="chi-table-container" style="background: #fff;">
          <table class="chi-contingency-table" id="expTable">
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>

    <div id="extremeAlert" class="chi-alert" style="display: none;">
      <div class="chi-alert-title">{ui.alertTitle}</div>
      <p class="chi-alert-body">{ui.alertBody}</p>
    </div>

    <section class="chi-results-grid">
      <div class="chi-stat-block" id="pvalueBlock">
        <div class="chi-stat-title">{ui.labelPValue}</div>
        <div class="chi-stat-value" id="res-pvalue">0.000</div>
        <div class="chi-stat-desc" id="res-desc">{ui.sigDescInitial}</div>
      </div>

      <div class="chi-stat-block">
        <div class="chi-stat-title">{ui.labelGlobalStats}</div>
        <div class="chi-stat-secondary-row">
          <div>
            <div class="chi-secondary-label">{ui.labelChiSquareStat}</div>
            <div class="chi-secondary-stat" id="res-chi">0.00</div>
          </div>
          <div>
            <div class="chi-secondary-label">{ui.labelDegrees}</div>
            <div class="chi-secondary-stat" id="res-df">1</div>
          </div>
        </div>
        <div class="chi-cramer-row">
          <div class="chi-secondary-label">{ui.labelCramer}</div>
          <div class="chi-cramer-value" id="res-cramer">
            0.00 <span class="chi-cramer-text" id="cramer-text">({ui.cramerNull})</span>
          </div>
        </div>
      </div>
    </section>

    <section class="chi-visual-section">
      <div class="chi-table-title" style="margin-bottom: 1rem;">
        <Icon name="mdi:chart-bar" /> {ui.labelVisualization}
      </div>
      <canvas id="bar-canvas"></canvas>
      <div class="chi-heatmap-info">{ui.heatmapInfo}</div>
    </section>

    <section class="chi-copy-block">
      <div class="chi-copy-header">
        <Icon name="mdi:text-box-outline" /> <span>{ui.labelReport}</span>
      </div>
      <p id="justificationText" class="chi-copy-text">{ui.defaultJustification}</p>
      <button class="chi-copy-btn" id="copyTextBtn">
        <Icon name="mdi:content-copy" /> {ui.btnCopy}
      </button>
    </section>
  </main>
</div>

<script>
  const app = document.getElementById('chiApp') as HTMLDivElement;
  if (!app) throw new Error('chiApp not found');

  const UI = {
    row: app.dataset.row ?? 'Row',
    col: app.dataset.col ?? 'Col',
    total: app.dataset.total ?? 'TOTAL',
    cramerNull: app.dataset.cramerNull ?? 'None',
    cramerWeak: app.dataset.cramerWeak ?? 'Weak',
    cramerModerate: app.dataset.cramerModerate ?? 'Moderate',
    cramerStrong: app.dataset.cramerStrong ?? 'Strong',
    sigText: app.dataset.sigText ?? '',
    noSigText: app.dataset.noSigText ?? '',
    chartObs: app.dataset.chartObs ?? 'Observed',
    chartExp: app.dataset.chartExp ?? 'Expected',
    copyLabel: app.dataset.copyLabel ?? 'Copy',
    copiedLabel: app.dataset.copiedLabel ?? 'Copied!',
    justIntro: app.dataset.justIntro ?? '',
    justTableOf: app.dataset.justTableOf ?? '',
    justObtained: app.dataset.justObtained ?? '',
    justPAt: app.dataset.justPAt ?? '',
    justConcluded: app.dataset.justConcluded ?? '',
    justSig: app.dataset.justSig ?? '',
    justNoSig: app.dataset.justNoSig ?? '',
  };

  const tableSize = document.getElementById('tableSize') as HTMLSelectElement;
  const alphaInput = document.getElementById('alpha') as HTMLSelectElement;
  const obsTable = document.querySelector('#obsTable tbody') as HTMLTableSectionElement;
  const expTable = document.querySelector('#expTable tbody') as HTMLTableSectionElement;
  const alertBox = document.getElementById('extremeAlert') as HTMLDivElement;

  const expectedBtn = document.getElementById('expectedBtn');
  const expectedContent = document.getElementById('expectedContent');
  const expectedIcon = document.getElementById('expectedIcon');

  expectedBtn?.addEventListener('click', () => {
    const isOpen = expectedContent?.classList.toggle('open');
    expectedIcon?.setAttribute('name', isOpen ? 'mdi:chevron-down' : 'mdi:chevron-right');
  });

  const canvas = document.getElementById('bar-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d');

  let rows = 2;
  let cols = 2;
  let obsData: number[][] = [];

  const normCDF = (x: number): number => {
    const t = 1 / (1 + 0.2316419 * Math.abs(x));
    const d = 0.3989422804 * Math.exp((-x * x) / 2);
    const p =
      d *
      t *
      (0.31938153 + t * (-0.356563782 + t * (1.781477937 + t * (-1.821255978 + t * 1.330274429))));
    return x > 0 ? 1 - p : p;
  };

  const chiSquareProb = (chi2: number, df: number): number => {
    if (chi2 <= 0) return 1;
    if (df === 1) return 2 * (1 - normCDF(Math.sqrt(chi2)));
    if (df === 2) return Math.exp(-chi2 / 2);
    if (df === 3)
      return (
        2 * (1 - normCDF(Math.sqrt(chi2))) + Math.sqrt((2 * chi2) / Math.PI) * Math.exp(-chi2 / 2)
      );
    if (df === 4) return Math.exp(-chi2 / 2) * (1 + chi2 / 2);
    return 0;
  };

  const generateTables = () => {
    const val = tableSize.value.split('x');
    rows = parseInt(val[0]!);
    cols = parseInt(val[1]!);

    let hHTML = `<tr class="chi-header-row"><th class="chi-header-col">#</th>`;
    for (let j = 0; j < cols; j++) hHTML += `<th>${UI.col} ${j + 1}</th>`;
    hHTML += `<th class="chi-total-cell">${UI.total}</th></tr>`;

    let bHTML = hHTML, eHTML = hHTML;

    for (let i = 0; i < rows; i++) {
      bHTML += `<tr><th class="chi-header-col">${UI.row} ${i + 1}</th>`; eHTML += `<tr><th class="chi-header-col">${UI.row} ${i + 1}</th>`;
      for (let j = 0; j < cols; j++) {
        bHTML += `<td><input type="number" class="chi-cell-input" data-r="${i}" data-c="${j}" value="10" min="0" step="1"/></td>`; eHTML += `<td id="exp-${i}-${j}">0.0</td>`;
      }
      bHTML += `<td class="chi-total-cell" id="rTot-${i}">0</td></tr>`; eHTML += `<td class="chi-total-cell" id="eTot-${i}">0</td></tr>`;
    }

    bHTML += `<tr><th class="chi-total-cell">${UI.total}</th>`; eHTML += `<tr><th class="chi-total-cell">${UI.total}</th>`;
    for (let j = 0; j < cols; j++) {
      bHTML += `<td class="chi-total-cell" id="cTot-${j}">0</td>`; eHTML += `<td class="chi-total-cell" id="ecTot-${j}">0</td>`;
    }
    bHTML += `<td class="chi-total-cell chi-grand-total" id="gTot">0</td></tr>`; eHTML += `<td class="chi-total-cell chi-grand-total" id="egTot">0</td></tr>`;

    obsTable.innerHTML = bHTML;
    expTable.innerHTML = eHTML;

    document.querySelectorAll('.chi-cell-input').forEach((inp) => {
      inp.addEventListener('input', calculate);
    });

    calculate();
  };

  const getMaxVal = (obs: number[][], exp: number[][]) => {
    let maxVal = 0;
    for (let i = 0; i < rows; i++)
      for (let j = 0; j < cols; j++) {
        if (obs[i]![j]! > maxVal) maxVal = obs[i]![j]!;
        if (exp[i]![j]! > maxVal) maxVal = exp[i]![j]!;
      }
    return maxVal * 1.1 || 10;
  };

  const drawChiGrid = (dims: { padL: number; padT: number; pw: number; ph: number }, maxVal: number) => {
    const { padL, padT, pw, ph } = dims;
    ctx!.strokeStyle = '#e2e8f0'; ctx!.lineWidth = 1; ctx!.beginPath();
    for (let i = 0; i <= 4; i++) {
      const y = padT + (i / 4) * ph;
      ctx!.moveTo(padL, y); ctx!.lineTo(padL + pw, y);
      ctx!.fillStyle = '#94a3b8'; ctx!.font = '10px sans-serif'; ctx!.textAlign = 'right';
      ctx!.fillText(Math.round(maxVal - (i / 4) * maxVal).toString(), padL - 8, y + 4);
    }
    ctx!.stroke();
  };

  const drawChiBarGroup = (j: number, obs: number[][], exp: number[][], opts: { padL: number; padT: number; ph: number; groupW: number; bw: number; ch: number; maxVal: number; colors: string[] }) => {
    const { padL, padT, ph, groupW, bw, ch, maxVal, colors } = opts;
    const gx = padL + j * groupW + groupW * 0.15;
    ctx!.fillStyle = '#64748b'; ctx!.font = 'bold 11px sans-serif'; ctx!.textAlign = 'center';
    ctx!.fillText(`${UI.col} ${j + 1}`, padL + j * groupW + groupW / 2, ch - 20);
    for (let i = 0; i < rows; i++) {
      const oH = (obs[i]![j]! / maxVal) * ph, eH = (exp[i]![j]! / maxVal) * ph;
      ctx!.fillStyle = colors[i % colors.length]!;
      ctx!.beginPath();
      ctx!.roundRect(gx + i * 2 * bw, padT + ph - oH, bw * 0.9, oH, [3, 3, 0, 0]);
      ctx!.fill();
      ctx!.fillStyle = '#cbd5e1'; ctx!.beginPath();
      ctx!.roundRect(gx + (i * 2 + 1) * bw, padT + ph - eH, bw * 0.9, eH, [3, 3, 0, 0]);
      ctx!.fill();
    }
  };

  const drawChiLegend = (padL: number, ch: number, colors: string[]) => {
    ctx!.fillStyle = colors[0]!; ctx!.fillRect(padL, ch - 10, 8, 8);
    ctx!.fillStyle = '#64748b'; ctx!.textAlign = 'left'; ctx!.fillText(UI.chartObs, padL + 12, ch - 2);
    ctx!.fillStyle = '#cbd5e1'; ctx!.fillRect(padL + 100, ch - 10, 8, 8);
    ctx!.fillStyle = '#64748b'; ctx!.fillText(UI.chartExp, padL + 112, ch - 2);
  };

  const drawChart = (obs: number[][], exp: number[][]) => {
    if (!ctx || !canvas) return;
    const dpr = window.devicePixelRatio || 1;
    const cw = canvas.offsetWidth, ch = canvas.offsetHeight;
    canvas.width = Math.round(cw * dpr); canvas.height = Math.round(ch * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0); ctx.clearRect(0, 0, cw, ch);
    const maxVal = getMaxVal(obs, exp);
    const padL = 30, padT = 20, padB = 40;
    const pw = cw - padL - 20, ph = ch - padT - padB;
    drawChiGrid({ padL, padT, pw, ph }, maxVal);
    const groupW = pw / cols, bw = (groupW * 0.7) / (rows * 2);
    const colors = ['#f59e0b', '#3b82f6', '#10b981'];
    for (let j = 0; j < cols; j++) drawChiBarGroup(j, obs, exp, { padL, padT, ph, groupW, bw, ch, maxVal, colors });
    drawChiLegend(padL, ch, colors);
  };

  const applyHeatmap = (inp: HTMLInputElement, e: number, obsVal: number) => {
    if (e <= 0) { inp.style.backgroundColor = 'transparent'; return; }
    const stdRes = (obsVal - e) / Math.sqrt(e);
    if (Math.abs(stdRes) > 2) {
      inp.style.backgroundColor = stdRes > 0 ? 'rgba(16, 185, 129, 0.15)' : 'rgba(239, 68, 68, 0.15)';
    } else if (Math.abs(stdRes) > 1) {
      inp.style.backgroundColor = stdRes > 0 ? 'rgba(16, 185, 129, 0.05)' : 'rgba(239, 68, 68, 0.05)';
    } else {
      inp.style.backgroundColor = 'transparent';
    }
  };

  const getCramerText = (cramer: number) => {
    if (cramer > 0.5) return UI.cramerStrong;
    if (cramer > 0.3) return UI.cramerModerate;
    if (cramer > 0.1) return UI.cramerWeak;
    return UI.cramerNull;
  };

  const computeTotals = () => {
    obsData = [];
    const rTot = new Array<number>(rows).fill(0);
    const cTot = new Array<number>(cols).fill(0);
    let total = 0;
    for (let i = 0; i < rows; i++) {
      obsData.push([]);
      for (let j = 0; j < cols; j++) {
        const inp = document.querySelector(`input[data-r="${i}"][data-c="${j}"]`) as HTMLInputElement;
        const v = Math.max(0, parseInt(inp.value) || 0);
        obsData[i]!.push(v);
        rTot[i]! += v; cTot[j]! += v; total += v;
      }
      document.getElementById(`rTot-${i}`)!.textContent = document.getElementById(`eTot-${i}`)!.textContent = rTot[i]!.toString();
    }
    for (let j = 0; j < cols; j++) {
      document.getElementById(`cTot-${j}`)!.textContent = document.getElementById(`ecTot-${j}`)!.textContent = cTot[j]!.toString();
    }
    document.getElementById('gTot')!.textContent = document.getElementById('egTot')!.textContent = total.toString();
    return { rTot, cTot, total };
  };

  const computeExpected = (rTot: number[], cTot: number[], total: number) => {
    let chi2 = 0;
    const expData: number[][] = [];
    let lowExpCount = 0;
    for (let i = 0; i < rows; i++) {
      expData.push([]);
      for (let j = 0; j < cols; j++) {
        const e = total > 0 ? (rTot[i]! * cTot[j]!) / total : 0;
        expData[i]!.push(e);
        document.getElementById(`exp-${i}-${j}`)!.textContent = e.toFixed(1);
        if (e > 0) chi2 += Math.pow(obsData[i]![j]! - e, 2) / e;
        if (e < 5 && e > 0) lowExpCount++;
        const inp = document.querySelector(`input[data-r="${i}"][data-c="${j}"]`) as HTMLInputElement;
        applyHeatmap(inp, e, obsData[i]![j]!);
      }
    }
    alertBox.style.display = lowExpCount > 0 ? 'block' : 'none';
    return { chi2, expData };
  };

  const updateCalcDisplay = (opts: { chi2: number; df: number; pValue: number; alpha: number; cramer: number; cramerTxt: string; total: number }) => {
    const { chi2, df, pValue, alpha, cramer, cramerTxt, total } = opts;
    const isSignificant = pValue < alpha;
    document.getElementById('res-chi')!.textContent = chi2.toFixed(3);
    document.getElementById('res-df')!.textContent = df.toString();
    document.getElementById('res-cramer')!.innerHTML = `${cramer.toFixed(2)} <span class="chi-cramer-text">(${cramerTxt})</span>`;
    const pvalBlock = document.getElementById('pvalueBlock')!;
    pvalBlock.className = 'chi-stat-block ' + (isSignificant ? 'significant' : 'not-significant');
    document.getElementById('res-pvalue')!.textContent = pValue < 0.001 ? '<0.001' : pValue.toFixed(4);
    document.getElementById('res-desc')!.textContent = isSignificant ? UI.sigText : UI.noSigText;
    const conclusion = isSignificant ? `${UI.justSig} ${cramer.toFixed(2)})` : UI.justNoSig;
    document.getElementById('justificationText')!.textContent =
      `${UI.justIntro} ${total} ${UI.justTableOf} ${rows}x${cols}${UI.justObtained} χ²(${df}) = ${chi2.toFixed(2)}, p = ${pValue.toFixed(4)}${UI.justPAt}${alpha}${UI.justConcluded} ${conclusion}.`;
  };

  const calculate = () => {
    const { rTot, cTot, total } = computeTotals();
    const { chi2, expData } = computeExpected(rTot, cTot, total);
    const df = (rows - 1) * (cols - 1);
    const pValue = chiSquareProb(chi2, df);
    const alpha = parseFloat(alphaInput.value) || 0.05;
    const maxDim = Math.min(rows, cols);
    const cramer = total > 0 && maxDim > 1 ? Math.sqrt(chi2 / (total * (maxDim - 1))) : 0;
    updateCalcDisplay({ chi2, df, pValue, alpha, cramer, cramerTxt: getCramerText(cramer), total });
    drawChart(obsData, expData);
  };

  tableSize.addEventListener('change', generateTables);
  alphaInput.addEventListener('change', calculate);
  window.addEventListener('resize', calculate);

  const copyBtn = document.getElementById('copyTextBtn');
  copyBtn?.addEventListener('click', () => {
    const text = document.getElementById('justificationText')?.textContent ?? '';
    navigator.clipboard.writeText(text);
    const t = copyBtn.innerHTML;
    copyBtn.innerHTML = UI.copiedLabel;
    setTimeout(() => (copyBtn.innerHTML = t), 1500);
  });

  generateTables();
</script>

