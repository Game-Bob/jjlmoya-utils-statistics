---
import { Icon } from 'astro-icon/components';
import type { ABTestUI } from './ui';

interface Props {
  ui: ABTestUI;
}

const { ui } = Astro.props;
---

<div
  class="ab-card"
  id="abTestApp"
  data-sig-text={ui.sigText}
  data-no-sig-text={ui.noSigText}
  data-confidence-prefix={ui.labelConfidencePrefix}
  data-just-intro={ui.justIntro}
  data-just-samples={ui.justSamples}
  data-just-respect-to={ui.justRespectTo}
  data-just-with-confidence={ui.justWithConfidence}
  data-just-diff={ui.justDiff}
  data-just-sig={ui.justSig}
  data-just-no-sig={ui.justNoSig}
  data-btn-copied={ui.btnCopied}
>
  <aside class="ab-sidebar">
    <div class="ab-sidebar-heading">
      <Icon name="mdi:tune-vertical" /> {ui.labelParams}
    </div>

    <div class="ab-toggle" id="testType">
      <button class="ab-toggle-btn active" data-type="proportions">{ui.btnConversions}</button>
      <button class="ab-toggle-btn" data-type="means">{ui.btnMeans}</button>
    </div>

    <div class="ab-group ab-group-a">
      <div class="ab-group-title">
        <Icon name="mdi:alpha-a-circle" /> {ui.labelGroupA}
      </div>
      <div class="ab-input-row">
        <label for="nA">{ui.labelTotalCases} <span class="ab-math">n₁</span></label>
        <input type="number" id="nA" value="1000" min="1" step="1" />
      </div>
      <div class="ab-input-row ab-type-prop">
        <label for="sA">{ui.labelSuccesses} <span class="ab-math">x₁</span></label>
        <input type="number" id="sA" value="150" min="0" step="1" />
      </div>
      <div class="ab-input-row ab-type-mean" style="display: none;">
        <label for="mA">{ui.labelMean} <span class="ab-math">μ₁</span></label>
        <input type="number" id="mA" value="50" step="0.1" />
      </div>
      <div class="ab-input-row ab-type-mean" style="display: none;">
        <label for="sdA">{ui.labelStdDev} <span class="ab-math">σ₁</span></label>
        <input type="number" id="sdA" value="10" min="0" step="0.1" />
      </div>
    </div>

    <div class="ab-group ab-group-b">
      <div class="ab-group-title ab-group-title-b">
        <Icon name="mdi:alpha-b-circle" /> {ui.labelGroupB}
      </div>
      <div class="ab-input-row">
        <label for="nB">{ui.labelTotalCases} <span class="ab-math">n₂</span></label>
        <input type="number" id="nB" value="1000" min="1" step="1" />
      </div>
      <div class="ab-input-row ab-type-prop">
        <label for="sB">{ui.labelSuccesses} <span class="ab-math">x₂</span></label>
        <input type="number" id="sB" value="200" min="0" step="1" />
      </div>
      <div class="ab-input-row ab-type-mean" style="display: none;">
        <label for="mB">{ui.labelMean} <span class="ab-math">μ₂</span></label>
        <input type="number" id="mB" value="53" step="0.1" />
      </div>
      <div class="ab-input-row ab-type-mean" style="display: none;">
        <label for="sdB">{ui.labelStdDev} <span class="ab-math">σ₂</span></label>
        <input type="number" id="sdB" value="10" min="0" step="0.1" />
      </div>
    </div>

    <div class="ab-group">
      <div class="ab-input-row">
        <label for="alpha">{ui.labelAlpha} <span class="ab-math">α</span></label>
        <select id="alpha" class="ab-select">
          <option value="0.10">{ui.alpha90}</option>
          <option value="0.05" selected>{ui.alpha95}</option>
          <option value="0.01">{ui.alpha99}</option>
        </select>
      </div>
      <div class="ab-input-row ab-direction-row">
        <label>{ui.labelDirection}</label>
        <div class="ab-toggle" id="tailsType">
          <button class="ab-toggle-btn active" data-type="two">{ui.btn2Tails}</button>
          <button class="ab-toggle-btn" data-type="one">{ui.btn1Tail}</button>
        </div>
      </div>
    </div>
  </aside>

  <main class="ab-main">
    <div id="extremeAlert" class="ab-alert" style="display: none;">
      <div class="ab-alert-title">{ui.alertTitle}</div>
      <p class="ab-alert-body">
        {ui.alertBody}
        <a href={ui.alertLinkUrl} class="ab-alert-link">{ui.alertLinkText}</a>.
      </p>
    </div>

    <section class="ab-results-grid">
      <div class="ab-pvalue-block" id="pvalueBlock">
        <div class="ab-pval-title">{ui.labelPValue} (<span class="ab-math">p</span>)</div>
        <div class="ab-pval-value" id="res-pvalue">0.000</div>
        <div class="ab-pval-desc" id="res-desc">{ui.sigDescInitial}</div>
      </div>

      <div class="ab-lift-block">
        <div class="ab-lift-header">
          <Icon name="mdi:rocket-launch" /> {ui.labelLift}
        </div>
        <div class="ab-lift-content">
          <span class="ab-lift-value" id="res-lift">0%</span>
          <span class="ab-lift-text">{ui.labelLiftText}</span>
        </div>
        <div class="ab-conf-bar-wrap">
          <div class="ab-conf-bar-fill" id="confBar"></div>
        </div>
        <div class="ab-conf-text" id="confText">{ui.labelConfidencePrefix} 0%</div>
      </div>
    </section>

    <section class="ab-visual">
      <div class="ab-block-title">
        <Icon name="mdi:chart-bell-curve" /> {ui.labelDistributions}
      </div>
      <p class="ab-chart-desc">{ui.chartDesc}</p>
      <canvas id="curves-canvas"></canvas>
    </section>

    <section class="ab-copy-block">
      <div class="ab-copy-header">
        <Icon name="mdi:text-box-outline" />
        <span>{ui.labelReport}</span>
      </div>
      <p id="justificationText" class="ab-copy-text">{ui.defaultJustification}</p>
      <button class="ab-copy-btn" id="copyTextBtn">
        <Icon name="mdi:content-copy" /> {ui.btnCopy}
      </button>
    </section>

  </main>
</div>

<script>
  const app = document.getElementById('abTestApp')!;
  const UI = {
    sigText: app.dataset.sigText ?? '',
    noSigText: app.dataset.noSigText ?? '',
    confidencePrefix: app.dataset.confidencePrefix ?? '',
    justIntro: app.dataset.justIntro ?? '',
    justSamples: app.dataset.justSamples ?? '',
    justRespectTo: app.dataset.justRespectTo ?? '',
    justWithConfidence: app.dataset.justWithConfidence ?? '',
    justDiff: app.dataset.justDiff ?? '',
    justSig: app.dataset.justSig ?? '',
    justNoSig: app.dataset.justNoSig ?? '',
    btnCopied: app.dataset.btnCopied ?? '',
  };

  const testTypeEl = document.getElementById('testType')!;
  const tailsTypeEl = document.getElementById('tailsType')!;
  const typeProps = document.querySelectorAll<HTMLElement>('.ab-type-prop');
  const typeMeans = document.querySelectorAll<HTMLElement>('.ab-type-mean');

  const nA = document.getElementById('nA') as HTMLInputElement;
  const sA = document.getElementById('sA') as HTMLInputElement;
  const mA = document.getElementById('mA') as HTMLInputElement;
  const sdA = document.getElementById('sdA') as HTMLInputElement;
  const nB = document.getElementById('nB') as HTMLInputElement;
  const sB = document.getElementById('sB') as HTMLInputElement;
  const mB = document.getElementById('mB') as HTMLInputElement;
  const sdB = document.getElementById('sdB') as HTMLInputElement;
  const alphaInput = document.getElementById('alpha') as HTMLSelectElement;
  const canvas = document.getElementById('curves-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d');

  let currentMode = 'proportions';
  let currentTails = 'two';

  const normCDF = (x: number): number => {
    const t = 1 / (1 + 0.2316419 * Math.abs(x));
    const d = 0.3989422804 * Math.exp((-x * x) / 2);
    const p =
      d * t * (0.31938153 + t * (-0.356563782 + t * (1.781477937 + t * (-1.821255978 + t * 1.330274429))));
    return x > 0 ? 1 - p : p;
  };

  const calcPValue = (Z: number, tails: string): number => {
    if (tails === 'two') return 2 * (1 - normCDF(Math.abs(Z)));
    return Z > 0 ? 1 - normCDF(Z) : 1;
  };

  const pdf = (x: number, m: number, s: number) =>
    (1 / (s * Math.sqrt(2 * Math.PI))) * Math.exp(-0.5 * Math.pow((x - m) / s, 2));

  const drawSingleCurve = (c: CanvasRenderingContext2D, opts: { m: number; s: number; color: string; fill: string; toX: (x: number) => number; toY: (y: number) => number; minX: number; maxX: number; range: number }) => {
    const { m, s, color, fill, toX, toY, minX, maxX, range } = opts;
    c.beginPath();
    c.moveTo(toX(minX), toY(0));
    for (let i = 0; i <= 150; i++) {
      const x = minX + (i / 150) * range;
      c.lineTo(toX(x), toY(pdf(x, m, s)));
    }
    c.lineTo(toX(maxX), toY(0));
    c.fillStyle = fill;
    c.fill();
    c.lineWidth = 2;
    c.strokeStyle = color;
    c.stroke();
    c.beginPath();
    c.setLineDash([4, 4]);
    c.moveTo(toX(m), toY(0));
    c.lineTo(toX(m), toY(pdf(m, m, s)));
    c.stroke();
    c.setLineDash([]);
  };

  const drawCurveLabels = (c: CanvasRenderingContext2D, opts: { meanA: number; meanB: number; pad: number; H: number; toX: (x: number) => number }) => {
    const { meanA, meanB, pad, H, toX } = opts;
    c.fillStyle = '#1e293b';
    c.font = 'bold 12px sans-serif';
    c.textAlign = 'center';
    const dA = currentMode === 'proportions' ? (meanA * 100).toFixed(1) + '%' : meanA.toFixed(2);
    const dB = currentMode === 'proportions' ? (meanB * 100).toFixed(1) + '%' : meanB.toFixed(2);
    c.fillText(`A: ${dA}`, toX(meanA), pad + H + 20);
    c.fillStyle = '#e11d48';
    c.fillText(`B: ${dB}`, toX(meanB), pad + H + 20);
  };

  const drawCurves = (meanA: number, seA: number, meanB: number, seB: number) => {
    if (!ctx) return;
    const dpr = window.devicePixelRatio || 1;
    const cw = canvas.offsetWidth, ch = canvas.offsetHeight;
    canvas.width = Math.round(cw * dpr);
    canvas.height = Math.round(ch * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    ctx.clearRect(0, 0, cw, ch);
    const pad = 30, W = cw - pad * 2, H = ch - pad * 2;
    const minX = Math.min(meanA - 4 * seA, meanB - 4 * seB);
    const maxX = Math.max(meanA + 4 * seA, meanB + 4 * seB);
    const range = maxX - minX || 1;
    const maxY = Math.max(1 / (seA * Math.sqrt(2 * Math.PI)), 1 / (seB * Math.sqrt(2 * Math.PI))) * 1.1;
    const toX = (x: number) => pad + ((x - minX) / range) * W;
    const toY = (y: number) => pad + H - (y / maxY) * H;
    ctx.beginPath();
    ctx.strokeStyle = '#cbd5e1';
    ctx.lineWidth = 1;
    ctx.moveTo(pad, pad + H);
    ctx.lineTo(pad + W, pad + H);
    ctx.stroke();
    const base = { toX, toY, minX, maxX, range };
    drawSingleCurve(ctx, { m: meanA, s: seA, color: '#64748b', fill: 'rgba(100,116,139,0.2)', ...base });
    drawSingleCurve(ctx, { m: meanB, s: seB, color: '#f43f5e', fill: 'rgba(244,63,94,0.2)', ...base });
    drawCurveLabels(ctx, { meanA, meanB, pad, H, toX });
  };

  const isExtreme = (sucA: number, numA: number, sucB: number, numB: number) =>
    sucA === 0 || sucB === 0 || sucA === numA || sucB === numB;

  const calcProportions = (numA: number, numB: number) => {
    const sucA = parseFloat(sA.value) || 0;
    const sucB = parseFloat(sB.value) || 0;
    const pA = sucA / numA;
    const pB = sucB / numB;
    const pooledP = (sucA + sucB) / (numA + numB);
    const se = Math.sqrt(pooledP * (1 - pooledP) * (1 / numA + 1 / numB));
    const seA = Math.sqrt((pA * (1 - pA)) / numA) || 0.0001;
    const seB = Math.sqrt((pB * (1 - pB)) / numB) || 0.0001;
    const Z = se > 0 ? (pB - pA) / se : 0;
    const pValue = se > 0 ? calcPValue(Z, currentTails) : 1;
    const lift = pA > 0 ? ((pB - pA) / pA) * 100 : 0;
    return { Z, pValue, lift, statA: pA, statB: pB, seA, seB, extreme: isExtreme(sucA, numA, sucB, numB) };
  };

  const calcMeans = (numA: number, numB: number) => {
    const meanAv = parseFloat(mA.value) || 0;
    const stdA = parseFloat(sdA.value) || 1;
    const meanBv = parseFloat(mB.value) || 0;
    const stdB = parseFloat(sdB.value) || 1;
    const seA = stdA / Math.sqrt(numA);
    const seB = stdB / Math.sqrt(numB);
    const se = Math.sqrt((stdA * stdA) / numA + (stdB * stdB) / numB);
    const Z = se > 0 ? (meanBv - meanAv) / se : 0;
    const pValue = se > 0 ? calcPValue(Z, currentTails) : 1;
    const lift = meanAv !== 0 ? ((meanBv - meanAv) / Math.abs(meanAv)) * 100 : 0;
    return { Z, pValue, lift, statA: meanAv, statB: meanBv, seA, seB, extreme: false };
  };

  const updateSignificance = (pValue: number, numA: number, numB: number, extreme: boolean) => {
    const alpha = parseFloat(alphaInput.value) || 0.05;
    const isSig = pValue < alpha;
    const pvalBlock = document.getElementById('pvalueBlock')!;
    pvalBlock.className = 'ab-pvalue-block ' + (isSig ? 'significant' : 'not-significant');
    document.getElementById('res-pvalue')!.textContent = pValue < 0.001 ? '<0.001' : pValue.toFixed(3);
    document.getElementById('res-desc')!.textContent = isSig ? UI.sigText : UI.noSigText;
    const alertBox = document.getElementById('extremeAlert')!;
    alertBox.style.display = numA < 30 || numB < 30 || extreme ? 'block' : 'none';
    return isSig;
  };

  const updateLift = (lift: number) => {
    const liftEl = document.getElementById('res-lift')!;
    liftEl.textContent = (lift > 0 ? '+' : '') + lift.toFixed(2) + '%';
    liftEl.className = 'ab-lift-value ' + (lift > 0 ? 'positive' : 'negative');
  };

  const update = () => {
    const numA = parseFloat(nA.value) || 1;
    const numB = parseFloat(nB.value) || 1;
    const r = currentMode === 'proportions' ? calcProportions(numA, numB) : calcMeans(numA, numB);
    const isSignificant = updateSignificance(r.pValue, numA, numB, r.extreme);
    updateLift(r.lift);
    const confidence = (1 - r.pValue) * 100;
    document.getElementById('confBar')!.style.width = Math.min(confidence, 100) + '%';
    document.getElementById('confText')!.textContent = UI.confidencePrefix + ' ' + confidence.toFixed(2) + '%';
    const total = numA + numB;
    const liftStr = (r.lift > 0 ? '+' : '') + r.lift.toFixed(2);
    const sigStr = isSignificant ? UI.justSig : UI.justNoSig;
    document.getElementById('justificationText')!.textContent =
      UI.justIntro + ' ' + total + UI.justSamples + liftStr + UI.justRespectTo +
      UI.justWithConfidence + confidence.toFixed(2) + '% (p=' + r.pValue.toFixed(3) + ')' +
      UI.justDiff + sigStr + '.';
    drawCurves(r.statA, r.seA, r.statB, r.seB);
  };

  testTypeEl.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>('.ab-toggle-btn');
    if (!btn) return;
    testTypeEl.querySelectorAll('.ab-toggle-btn').forEach((b) => b.classList.remove('active'));
    btn.classList.add('active');
    currentMode = btn.dataset.type!;
    typeProps.forEach((el) => { el.style.display = currentMode === 'proportions' ? 'flex' : 'none'; });
    typeMeans.forEach((el) => { el.style.display = currentMode === 'means' ? 'flex' : 'none'; });
    update();
  });

  tailsTypeEl.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>('.ab-toggle-btn');
    if (!btn) return;
    tailsTypeEl.querySelectorAll('.ab-toggle-btn').forEach((b) => b.classList.remove('active'));
    btn.classList.add('active');
    currentTails = btn.dataset.type!;
    update();
  });

  [nA, sA, mA, sdA, nB, sB, mB, sdB, alphaInput].forEach((el) => {
    el.addEventListener('input', update);
    el.addEventListener('change', update);
  });

  window.addEventListener('resize', update);

  const copyBtn = document.getElementById('copyTextBtn')!;
  copyBtn.addEventListener('click', () => {
    const text = document.getElementById('justificationText')!.textContent || '';
    navigator.clipboard.writeText(text);
    const original = copyBtn.innerHTML;
    copyBtn.textContent = UI.btnCopied;
    setTimeout(() => { copyBtn.innerHTML = original; }, 1500);
  });

  update();
</script>

