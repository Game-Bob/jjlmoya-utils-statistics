---
import { Icon } from 'astro-icon/components';
import type { PearsonCorrelationUI } from './ui';

interface Props {
  ui: PearsonCorrelationUI;
}

const { ui } = Astro.props;
---

<div
  class="pc-card"
  id="pearsonApp"
  data-interp-perfect-pos={ui.interpPerfectPos}
  data-interp-perfect-neg={ui.interpPerfectNeg}
  data-interp-strong={ui.interpStrong}
  data-interp-moderate={ui.interpModerate}
  data-interp-weak={ui.interpWeak}
  data-error-msg={ui.errorMsg}
>
  <aside class="pc-sidebar">
    <header class="pc-sidebar-header">
      <h3 class="pc-sidebar-title">
        <Icon name="mdi:database-import" /> {ui.headingData}
      </h3>
      <div class="pc-btn-group">
        <button id="loadExample" class="pc-icon-btn" title={ui.btnLoadExample}>
          <Icon name="mdi:lightbulb-outline" />
        </button>
        <button id="clearData" class="pc-icon-btn" title={ui.btnClear}>
          <Icon name="mdi:trash-can-outline" />
        </button>
      </div>
    </header>

    <textarea id="dataInput" class="pc-textarea" placeholder={ui.placeholder}></textarea>

    <div class="pc-setting-row">
      <label for="decimalSeparator" class="pc-setting-label">{ui.labelDecimalSep}</label>
      <select id="decimalSeparator" class="pc-setting-select">
        <option value=".">{ui.optPoint}</option>
        <option value=",">{ui.optComma}</option>
      </select>
    </div>

    <div class="pc-privacy-badge">
      <Icon name="mdi:shield-check" />
      <span>{ui.privacyBadge}</span>
    </div>
  </aside>

  <main class="pc-main">
    <div class="pc-results-top">
      <div class="pc-main-stat">
        <div id="rValue" class="pc-r-value">-</div>
        <div class="pc-r-label">{ui.labelR}</div>
      </div>

      <div class="pc-stats-grid">
        <div class="pc-stat-group">
          <span class="pc-stat-label">{ui.labelR2}</span>
          <span id="r2Value" class="pc-stat-value">-</span>
        </div>
        <div class="pc-stat-group">
          <span class="pc-stat-label">{ui.labelN}</span>
          <span id="nValue" class="pc-stat-value">0</span>
        </div>
        <div class="pc-stat-group">
          <span class="pc-stat-label">{ui.labelSlope}</span>
          <span id="slopeValue" class="pc-stat-value">-</span>
        </div>
        <div class="pc-stat-group">
          <span class="pc-stat-label">{ui.labelMeanXY}</span>
          <span class="pc-stat-value pc-stat-means">
            <span id="meanX">-</span> | <span id="meanY">-</span>
          </span>
        </div>
      </div>
    </div>

    <div class="pc-canvas-wrap" id="canvasWrapper">
      <canvas id="scatterPlot"></canvas>
      <div class="pc-error-overlay" id="errorLabel" style="display: none;">
        <Icon name="mdi:alert-circle" />
        <p id="errorMsg">{ui.errorMsg}</p>
      </div>
    </div>

    <div class="pc-actions-row">
      <div id="interpretation" class="pc-interp-badge">{ui.labelWaiting}</div>
      <div class="pc-btn-group">
        <div id="regressionEq" class="pc-regression-eq" style="display: none;">y = mx + b</div>
        <button id="copyResults" class="pc-icon-btn" title={ui.btnCopyTitle}>
          <Icon name="mdi:content-copy" />
        </button>
        <button id="downloadChart" class="pc-icon-btn" title={ui.btnDownloadTitle}>
          <Icon name="mdi:download" />
        </button>
      </div>
    </div>
  </main>
</div>

<script>
  const app = document.getElementById('pearsonApp')!;
  const UI = {
    interpPerfectPos: app.dataset.interpPerfectPos ?? '',
    interpPerfectNeg: app.dataset.interpPerfectNeg ?? '',
    interpStrong: app.dataset.interpStrong ?? '',
    interpModerate: app.dataset.interpModerate ?? '',
    interpWeak: app.dataset.interpWeak ?? '',
    errorMsg: app.dataset.errorMsg ?? '',
  };

  const dataInput = document.getElementById('dataInput') as HTMLTextAreaElement;
  const decimalSep = document.getElementById('decimalSeparator') as HTMLSelectElement;
  const loadExampleBtn = document.getElementById('loadExample');
  const clearDataBtn = document.getElementById('clearData');
  const downloadChartBtn = document.getElementById('downloadChart');
  const copyResultsBtn = document.getElementById('copyResults');
  const errorLabel = document.getElementById('errorLabel')!;
  const errorMsgEl = document.getElementById('errorMsg')!;
  const canvas = document.getElementById('scatterPlot') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d');
  const regressionEq = document.getElementById('regressionEq')!;

  const ui = {
    r: document.getElementById('rValue')!,
    r2: document.getElementById('r2Value')!,
    n: document.getElementById('nValue')!,
    slope: document.getElementById('slopeValue')!,
    meanX: document.getElementById('meanX')!,
    meanY: document.getElementById('meanY')!,
    inter: document.getElementById('interpretation')!,
  };

  const EXAMPLE = '10, 15\n12, 18\n15, 22\n18, 28\n20, 32\n22, 35\n25, 42\n30, 50';

  interface Point { x: number; y: number; }

  const cleanValue = (val: string, sep: string): number | null => {
    let s = val.trim().replace(/[$%€£¥]/g, '');
    if (sep === ',') s = s.replace(/\./g, '').replace(',', '.');
    else s = s.replace(/,/g, '');
    const n = parseFloat(s);
    return isNaN(n) ? null : n;
  };

  const parseData = (text: string, sep: string): Point[] =>
    text.split(/\r?\n/).reduce((acc, line) => {
      const parts = line.trim().split(/[\t,;|\s+]+/).filter((p) => p !== '');
      if (parts.length >= 2) {
        const x = cleanValue(parts[0], sep), y = cleanValue(parts[1], sep);
        if (x !== null && y !== null) acc.push({ x, y });
      }
      return acc;
    }, [] as Point[]);

  const calculateStats = (pts: Point[]) => {
    const n = pts.length;
    if (n < 2) return null;
    const sumX = pts.reduce((a, b) => a + b.x, 0);
    const sumY = pts.reduce((a, b) => a + b.y, 0);
    const mx = sumX / n, my = sumY / n;
    let num = 0, denX = 0, denY = 0;
    pts.forEach((p) => {
      const dx = p.x - mx, dy = p.y - my;
      num += dx * dy; denX += dx * dx; denY += dy * dy;
    });
    const r = num / Math.sqrt(denX * denY);
    const m = num / denX, b = my - m * mx;
    return { r, r2: r * r, n, m, b, meanX: mx, meanY: my };
  };

  const drawChart = (pts: Point[], stats: ReturnType<typeof calculateStats>) => {
    if (!ctx) return;
    const container = canvas.parentElement!;
    const dpr = window.devicePixelRatio || 1;
    const rect = container.getBoundingClientRect();
    canvas.width = Math.round(rect.width * dpr);
    canvas.height = Math.round(rect.height * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    const w = rect.width, h = rect.height, pad = 30;
    ctx.clearRect(0, 0, w, h);
    if (pts.length < 1) return;

    const minX = Math.min(...pts.map((p) => p.x)), maxX = Math.max(...pts.map((p) => p.x));
    const minY = Math.min(...pts.map((p) => p.y)), maxY = Math.max(...pts.map((p) => p.y));
    const rX = maxX - minX || 1, rY = maxY - minY || 1;
    const x0 = minX - rX * 0.1, x1 = maxX + rX * 0.1;
    const y0 = minY - rY * 0.1, y1 = maxY + rY * 0.1;
    const toX = (v: number) => pad + ((v - x0) / (x1 - x0)) * (w - 2 * pad);
    const toY = (v: number) => h - pad - ((v - y0) / (y1 - y0)) * (h - 2 * pad);

    if (stats) {
      ctx.strokeStyle = 'rgba(236,72,153,0.4)';
      ctx.lineWidth = 2;
      ctx.setLineDash([5, 5]);
      ctx.beginPath();
      ctx.moveTo(toX(x0), toY(stats.m * x0 + stats.b));
      ctx.lineTo(toX(x1), toY(stats.m * x1 + stats.b));
      ctx.stroke();
      ctx.setLineDash([]);
    }
    pts.forEach((p) => {
      ctx.fillStyle = '#6366f1';
      ctx.beginPath();
      ctx.arc(toX(p.x), toY(p.y), 4, 0, Math.PI * 2);
      ctx.fill();
    });
  };

  const setInterp = (text: string, cls: string) => {
    ui.inter.textContent = text;
    ui.inter.className = 'pc-interp-badge ' + cls;
  };

  const updateResults = () => {
    const text = dataInput.value;
    const pts = parseData(text, decimalSep.value);
    const stats = calculateStats(pts);
    localStorage.setItem('pearson_data', text);

    if (stats) {
      ui.r.textContent = stats.r.toFixed(4);
      ui.r2.textContent = (stats.r2 * 100).toFixed(1) + '%';
      ui.n.textContent = stats.n.toString();
      ui.slope.textContent = stats.m.toFixed(2);
      ui.meanX.textContent = stats.meanX.toFixed(2);
      ui.meanY.textContent = stats.meanY.toFixed(2);
      regressionEq.style.display = 'block';
      regressionEq.textContent = `y = ${stats.m.toFixed(2)}x + ${stats.b.toFixed(2)}`;

      const absR = Math.abs(stats.r);
      if (absR >= 0.999) {
        setInterp(stats.r > 0 ? UI.interpPerfectPos : UI.interpPerfectNeg, 'pc-interp--strong');
      } else if (absR >= 0.7) {
        setInterp(UI.interpStrong, 'pc-interp--strong');
      } else if (absR >= 0.4) {
        setInterp(UI.interpModerate, 'pc-interp--moderate');
      } else {
        setInterp(UI.interpWeak, 'pc-interp--weak');
      }
      errorLabel.style.display = 'none';
    } else {
      errorMsgEl.textContent = UI.errorMsg;
      errorLabel.style.display = text.trim() ? 'flex' : 'none';
      regressionEq.style.display = 'none';
      [ui.r, ui.r2, ui.slope, ui.meanX, ui.meanY].forEach((el) => { el.textContent = '-'; });
    }
    drawChart(pts, stats);
  };

  dataInput.addEventListener('input', updateResults);
  decimalSep.addEventListener('change', updateResults);
  loadExampleBtn?.addEventListener('click', () => { dataInput.value = EXAMPLE; updateResults(); });
  clearDataBtn?.addEventListener('click', () => { dataInput.value = ''; updateResults(); });

  downloadChartBtn?.addEventListener('click', () => {
    const a = document.createElement('a');
    a.download = 'pearson.webp';
    a.href = canvas.toDataURL('image/webp');
    a.click();
  });

  copyResultsBtn?.addEventListener('click', () => {
    navigator.clipboard.writeText(
      `R=${ui.r.textContent}, R²=${ui.r2.textContent}. ${regressionEq.textContent}`
    );
    const orig = copyResultsBtn.innerHTML;
    copyResultsBtn.innerHTML = '<svg style="width:18px;height:18px" viewBox="0 0 24 24"><path fill="currentColor" d="M21,7L9,19L3.5,13.5L4.91,12.09L9,16.17L19.59,5.59L21,7Z" /></svg>';
    setTimeout(() => { copyResultsBtn.innerHTML = orig; }, 2000);
  });

  const saved = localStorage.getItem('pearson_data');
  if (saved) { dataInput.value = saved; updateResults(); }
  window.addEventListener('resize', updateResults);
</script>

<style>
  :global(.pc-card) {
    --pc-bg: rgba(255, 255, 255, 0.7);
    --pc-border: rgba(99, 102, 241, 0.15);
    --pc-shadow: rgba(0, 0, 0, 0.08);
    --pc-sidebar-bg: rgba(99, 102, 241, 0.03);
    --pc-sidebar-border: rgba(99, 102, 241, 0.1);
    --pc-primary: #6366f1;
    --pc-accent: #ec4899;
    --pc-text: #1e293b;
    --pc-text-muted: #64748b;
    --pc-text-label: #64748b;
    --pc-input-bg: #ffffff;
    --pc-input-border: #e2e8f0;
    --pc-input-border-focus: #6366f1;
    --pc-surface: rgba(255, 255, 255, 0.5);
    --pc-surface-border: rgba(99, 102, 241, 0.05);
    --pc-icon-btn-bg: #ffffff;
    --pc-icon-btn-border: #e2e8f0;
    --pc-icon-btn-color: #64748b;
    --pc-stat-value: #1e293b;
    --pc-actions-border: rgba(99, 102, 241, 0.1);
    --pc-main-stat-border: rgba(99, 102, 241, 0.1);
    --pc-privacy-color: #94a3b8;
    --pc-privacy-border: rgba(99, 102, 241, 0.1);
    --pc-error-bg: rgba(255, 255, 255, 0.9);
    --pc-error-color: #ef4444;

    background: var(--pc-bg);
    backdrop-filter: blur(12px);
    border-radius: 2rem;
    border: 1px solid var(--pc-border);
    box-shadow: 0 20px 40px -15px var(--pc-shadow);
    max-width: 1100px;
    margin: 0 auto;
    overflow: hidden;
    display: grid;
    grid-template-columns: 350px 1fr;
    min-height: 600px;
  }

  :global(.theme-dark .pc-card) {
    --pc-bg: rgba(24, 24, 27, 0.95);
    --pc-border: rgba(99, 102, 241, 0.2);
    --pc-shadow: rgba(0, 0, 0, 0.3);
    --pc-sidebar-bg: rgba(99, 102, 241, 0.04);
    --pc-sidebar-border: rgba(255, 255, 255, 0.05);
    --pc-primary: #818cf8;
    --pc-accent: #f472b6;
    --pc-text: #f1f5f9;
    --pc-text-muted: #94a3b8;
    --pc-text-label: #94a3b8;
    --pc-input-bg: #0f172a;
    --pc-input-border: #334155;
    --pc-input-border-focus: #818cf8;
    --pc-surface: rgba(15, 23, 42, 0.3);
    --pc-surface-border: rgba(99, 102, 241, 0.08);
    --pc-icon-btn-bg: #1e293b;
    --pc-icon-btn-border: #334155;
    --pc-icon-btn-color: #94a3b8;
    --pc-stat-value: #f1f5f9;
    --pc-actions-border: rgba(99, 102, 241, 0.15);
    --pc-main-stat-border: rgba(99, 102, 241, 0.15);
    --pc-privacy-color: #475569;
    --pc-privacy-border: rgba(255, 255, 255, 0.05);
    --pc-error-bg: rgba(15, 23, 42, 0.9);
    --pc-error-color: #f87171;
  }

  :global(.pc-sidebar) {
    background: var(--pc-sidebar-bg);
    border-right: 1px solid var(--pc-sidebar-border);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  :global(.pc-sidebar-header) {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  :global(.pc-sidebar-title) {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--pc-primary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  :global(.pc-textarea) {
    flex: 1;
    width: 100%;
    min-height: 300px;
    background: var(--pc-input-bg);
    border: 2px solid var(--pc-input-border);
    border-radius: 1rem;
    padding: 1rem;
    font-size: 0.875rem;
    resize: none;
    transition: all 0.2s ease;
    color: var(--pc-text);
    box-sizing: border-box;
  }

  :global(.pc-textarea:focus) {
    outline: none;
    border-color: var(--pc-input-border-focus);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
  }

  :global(.pc-setting-row) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  :global(.pc-setting-label) {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--pc-text-label);
    text-transform: uppercase;
  }

  :global(.pc-setting-select) {
    padding: 0.25rem 0.5rem;
    border-radius: 0.5rem;
    border: 1px solid var(--pc-input-border);
    font-size: 0.75rem;
    background: var(--pc-input-bg);
    color: var(--pc-text);
    cursor: pointer;
  }

  :global(.pc-privacy-badge) {
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px dashed var(--pc-privacy-border);
    font-size: 0.7rem;
    color: var(--pc-privacy-color);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  :global(.pc-main) {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  :global(.pc-results-top) {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2rem;
    align-items: center;
  }

  :global(.pc-main-stat) {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding-right: 2rem;
    border-right: 2px solid var(--pc-main-stat-border);
    min-width: 200px;
  }

  :global(.pc-r-value) {
    font-size: 4rem;
    font-weight: 950;
    letter-spacing: -2px;
    line-height: 1;
    background: linear-gradient(135deg, #6366f1, #ec4899);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-align: center;
    width: 100%;
  }

  :global(.pc-r-label) {
    font-size: 0.75rem;
    text-transform: uppercase;
    font-weight: 800;
    color: var(--pc-text-muted);
    margin-top: 0.5rem;
  }

  :global(.pc-stats-grid) {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1.5rem;
  }

  :global(.pc-stat-group) {
    display: flex;
    flex-direction: column;
  }

  :global(.pc-stat-label) {
    font-size: 0.7rem;
    color: var(--pc-text-label);
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }

  :global(.pc-stat-value) {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--pc-stat-value);
  }

  :global(.pc-stat-means) { font-size: 1rem !important; }

  :global(.pc-canvas-wrap) {
    background: var(--pc-surface);
    border: 1px solid var(--pc-surface-border);
    border-radius: 1.5rem;
    padding: 1rem;
    position: relative;
    overflow: hidden;
  }

  :global(#scatterPlot) {
    display: block;
    width: 100%;
    height: 280px;
  }

  :global(.pc-error-overlay) {
    position: absolute;
    inset: 0;
    background: var(--pc-error-bg);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border-radius: 1.5rem;
    color: var(--pc-error-color);
    font-weight: 600;
    font-size: 0.85rem;
    text-align: center;
    padding: 2rem;
    gap: 0.75rem;
  }

  :global(.pc-actions-row) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--pc-actions-border);
    padding-top: 1.5rem;
  }

  :global(.pc-interp-badge) {
    padding: 0.5rem 1.25rem;
    border-radius: 100px;
    font-weight: 700;
    font-size: 0.85rem;
    background: rgba(99, 102, 241, 0.05);
    color: var(--pc-text-muted);
  }

  :global(.pc-interp--strong) {
    background: #dcfce7;
    color: #166534;
  }

  :global(.theme-dark .pc-interp--strong) {
    background: rgba(22, 163, 74, 0.15);
    color: #86efac;
  }

  :global(.pc-interp--moderate) {
    background: #fef9c3;
    color: #854d0e;
  }

  :global(.theme-dark .pc-interp--moderate) {
    background: rgba(202, 138, 4, 0.15);
    color: #fde047;
  }

  :global(.pc-interp--weak) {
    background: #f1f5f9;
    color: #475569;
  }

  :global(.theme-dark .pc-interp--weak) {
    background: #27272a;
    color: #a1a1aa;
  }

  :global(.pc-btn-group) {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  :global(.pc-regression-eq) {
    font-size: 0.75rem;
    color: var(--pc-text-muted);
    margin-right: 1rem;
  }

  :global(.pc-icon-btn) {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: var(--pc-icon-btn-bg);
    border: 1px solid var(--pc-icon-btn-border);
    color: var(--pc-icon-btn-color);
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  :global(.pc-icon-btn:hover) {
    transform: translateY(-2px);
    border-color: var(--pc-primary);
    color: var(--pc-primary);
  }

  :global(.pc-main > *),
  :global(.pc-sidebar > *) { min-width: 0; }

  @media (max-width: 900px) {
    :global(.pc-card) { grid-template-columns: 1fr; }
    :global(.pc-sidebar) {
      border-right: none;
      border-bottom: 1px solid var(--pc-sidebar-border);
      padding: 1.5rem;
    }
    :global(.pc-textarea) { min-height: 150px; }
  }

  @media (max-width: 600px) {
    :global(.pc-card) { border-radius: 1rem; margin: 0; }
    :global(.pc-sidebar) { padding: 1.25rem; }
    :global(.pc-main) { padding: 1.25rem; gap: 1.25rem; }
    :global(.pc-results-top) { grid-template-columns: 1fr; gap: 1rem; }
    :global(.pc-main-stat) {
      border-right: none;
      border-bottom: 2px solid var(--pc-main-stat-border);
      padding-right: 0;
      padding-bottom: 1rem;
      min-width: unset;
    }
    :global(.pc-r-value) { font-size: 2.5rem; letter-spacing: -1px; }
    :global(.pc-stats-grid) { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    :global(.pc-actions-row) { flex-direction: column; gap: 0.75rem; align-items: flex-start; }
    :global(.pc-interp-badge) { font-size: 0.8rem; padding: 0.4rem 1rem; }
    :global(.pc-canvas-wrap) { border-radius: 1rem; }
    :global(#scatterPlot) { height: 200px; }
  }
</style>
